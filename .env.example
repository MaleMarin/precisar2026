# Copiar a `.env.local` en local. En Vercel: Project → Settings → Environment Variables
# (Production / Preview / Development según necesites).
#
# Despliegue Vercel (repo precisar2026): Root Directory DEBE estar VACÍO o `.`
# (la app Next está en la raíz del repo). NO pongas dominios ni `web` aquí.
# Framework: Next.js; Build: npm run build; Install: npm install.
#
# Origen canónico del sitio: ver `src/lib/site.ts` (`https://precisar.net`).

# -----------------------------------------------------------------------------
# Resend — correo de contacto + avisos automáticos (newsletter, consulta)
# Crea API key: https://resend.com/api-keys
# Remitente verificado (ej. Precisar <notificaciones@precisar.dev>)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
FOOTER_CONTACT_FROM=
FOOTER_CONTACT_TO=male@precisar.net
# PRECISAR_NOTIFY_TO=

# Newsletter — opción A: proveedor externo (Mailchimp, Brevo, etc.). Tiene prioridad si está definida.
NEXT_PUBLIC_NEWSLETTER_FORM_ACTION=

# Newsletter — opción B: Firestore (mismo proyecto que la consulta ciudadana).
# El formulario envía a POST /api/newsletter/subscribe (servidor → Firestore).
# Colección por defecto: newsletter_suscripciones. Reglas: permitir create anónimo en esa colección.
# NEXT_PUBLIC_FIREBASE_NEWSLETTER_COLLECTION=newsletter_suscripciones
#
# En Vercel puedes usar las mismas claves con prefijo NEXT_PUBLIC_ (redeploy obligatorio)
# o solo en servidor (sin NEXT_PUBLIC_, lectura en runtime; útil si olvidaste redeploy):
# FIREBASE_ENCUESTA_API_KEY=
# FIREBASE_ENCUESTA_AUTH_DOMAIN=encuesta-informacion.firebaseapp.com
# FIREBASE_ENCUESTA_PROJECT_ID=encuesta-informacion
# FIREBASE_ENCUESTA_STORAGE_BUCKET=encuesta-informacion.firebasestorage.app
# FIREBASE_ENCUESTA_MESSAGING_SENDER_ID=853324167182
# FIREBASE_ENCUESTA_APP_ID=

# Hero de portada: URLs opcionales a video/póster propios.
# NEXT_PUBLIC_PRECISAR_HERO_MP4=
# NEXT_PUBLIC_PRECISAR_HERO_WEBM=
# NEXT_PUBLIC_PRECISAR_HERO_POSTER=

# -----------------------------------------------------------------------------
# Firebase — consulta ciudadana (/consulta) → Firestore proyecto Encuesta Información
# Consola: https://console.firebase.google.com/project/encuesta-informacion
# Añade las mismas claves en Vercel (Production / Preview) para que el envío funcione en producción.
# En Vercel NO uses comillas en los valores (mal: "encuesta-informacion" · bien: encuesta-informacion).
# Reglas Firestore: permitir create en la colección (p. ej. consulta_respuestas) para clientes anónimos
# o restringir con App Check / validación según tu modelo de riesgo.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_ENCUESTA_API_KEY=
NEXT_PUBLIC_FIREBASE_ENCUESTA_AUTH_DOMAIN=encuesta-informacion.firebaseapp.com
NEXT_PUBLIC_FIREBASE_ENCUESTA_PROJECT_ID=encuesta-informacion
NEXT_PUBLIC_FIREBASE_ENCUESTA_STORAGE_BUCKET=encuesta-informacion.firebasestorage.app
NEXT_PUBLIC_FIREBASE_ENCUESTA_MESSAGING_SENDER_ID=853324167182
NEXT_PUBLIC_FIREBASE_ENCUESTA_APP_ID=
# Opcional (Analytics web); el envío a Firestore no lo requiere.
# NEXT_PUBLIC_FIREBASE_ENCUESTA_MEASUREMENT_ID=
# Opcional: nombre de colección (por defecto consulta_respuestas).
# NEXT_PUBLIC_FIREBASE_CONSULTA_COLLECTION=consulta_respuestas
