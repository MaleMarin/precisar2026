rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /survey_responses_2026/{docId} {
      allow create, update: if true;
      allow read, delete: if false;
    }

    match /survey_responses_v6/{docId} {
      allow create, update: if true;
      allow read, delete: if false;
    }

    match /survey_responses/{docId} {
      allow create, update: if true;
      allow read, delete: if false;
    }

    match /consulta_respuestas/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /newsletter_suscripciones/{id} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320;
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
