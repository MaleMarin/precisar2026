[debug] [2026-05-18T17:09:11.795Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/encuesta-informacion/rulesets {"name":"projects/encuesta-informacion/rulesets/c9c87b56-749d-49ce-ae3c-6d9da983e900","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    match /survey_responses_2026/{docId} {\n      allow create, update: if true;\n      allow read, delete: if false;\n    }\n\n    match /survey_responses_v6/{docId} {\n      allow create, update: if true;\n      allow read, delete: if false;\n    }\n\n    match /survey_responses/{docId} {\n      allow create, update: if true;\n      allow read, delete: if false;\n    }\n\n    match /consulta_respuestas/{id} {\n      allow create: if true;\n      allow read, update, delete: if false;\n    }\n\n    match /newsletter_suscripciones/{id} {\n      allow create: if request.resource.data.email is string\n        && request.resource.data.email.size() > 3\n        && request.resource.data.email.size() < 320;\n      allow read, update, delete: if false;\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-18T17:09:10.856527Z","metadata":{"services":["cloud.firestore"]}}
